[run]
# Cover both the legacy AutoPenX package and the new cet4_app src-layout package
# so a single `coverage` run can fail-under on the combined suite.
source =
    autopnex
    src/cet4_app

branch = true

omit =
    autopnex/web/static/*
    */__pycache__/*
    */tests/*
    */.venv/*
    */site-packages/*

[paths]
# Normalize the src-layout path so that `coverage combine` and reports work
# regardless of whether tests were run against the installed package or the
# source tree.
cet4_app =
    src/cet4_app
    */site-packages/cet4_app

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    if TYPE_CHECKING:
show_missing = true
skip_covered = false
