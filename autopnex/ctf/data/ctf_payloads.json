  "crypto": {
    "rsa": [
      "from Crypto.Util.number import long_to_bytes, inverse; m = pow(c, d, n); print(long_to_bytes(m))",
      "import gmpy2; m = gmpy2.iroot(c, e)[0]; print(long_to_bytes(int(m)))",
      "from sympy import factorint; factors = factorint(n); p, q = list(factors.keys())",
      "d = inverse(e, (p-1)*(q-1)); m = pow(c, d, n)",
      "# Wiener attack: from owiener import attack; d = attack(e, n)",
      "# Fermat factorization: a = isqrt(n)+1; b2 = a*a - n; b = isqrt(b2)"
    ],
    "xor": [
      "from pwn import xor; result = xor(ciphertext, key)",
      "result = bytes([c ^ k for c, k in zip(ciphertext, itertools.cycle(key))])",
      "# Single byte XOR brute: [bytes([b ^ k for b in ct]) for k in range(256)]",
      "# Known plaintext: key = xor(ciphertext[:len(known)], known)",
      "from Crypto.Util.strxor import strxor; plain = strxor(ct, key)"
    ],
    "classical": [
      "# Caesar brute: [''.join(chr((ord(c)-65+i)%26+65) for c in ct) for i in range(26)]",
      "# Vigenere: key_len via Kasiski; then frequency analysis per position",
      "# Rail fence: read diagonally with n rails",
      "# Substitution: frequency analysis + quipqiup.com",
      "# Atbash: ''.join(chr(155 - ord(c)) if c.isalpha() else c for c in ct)"
    ],
    "hash": [
      "import hashlib; hashlib.md5(b'candidate').hexdigest()",
      "# hashcat -m 0 hash.txt wordlist.txt",
      "# john --format=raw-md5 hash.txt",
      "# Online: crackstation.net, hashes.org",
      "# Rainbow table: rtgen md5 loweralpha 1 7 0 3800 33554432 0"
    ],
    "aes": [
      "from Crypto.Cipher import AES; cipher = AES.new(key, AES.MODE_ECB); plain = cipher.decrypt(ct)",
      "# CBC bit-flipping: ct[i] ^= old_byte ^ new_byte",
      "# Padding oracle: modify ct block and observe padding errors",
      "from Crypto.Cipher import AES; cipher = AES.new(key, AES.MODE_CBC, iv); plain = cipher.decrypt(ct)",
      "# ECB detection: check for repeated 16-byte blocks in ciphertext"
    ]
  },
